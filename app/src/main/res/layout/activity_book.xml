<?xml version="1.0" encoding="utf-8"?>
<RelativeLayout
    xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    xmlns:tools="http://schemas.android.com/tools"
    android:id="@+id/main"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    tools:context=".main.BookActivity">

    <ImageView
        android:id="@+id/bookActivity_IV_bookImage"
        android:layout_width="match_parent"
        android:layout_height="200dp"/>
    <TextView
        android:id="@+id/bookActivity_TV_bookName"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:layout_below="@id/bookActivity_IV_bookImage"
        android:text="Book name"
        android:textColor="@color/blue"
        android:textSize="20sp"
        android:layout_marginTop="10dp"
        android:layout_marginHorizontal="10dp"
        android:textStyle="bold"
        />
    <TextView
        android:id="@+id/bookActivity_TV_bookPrice"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:text="100$"
        android:layout_marginHorizontal="10dp"
        android:textColor="@color/orange"
        android:textSize="18sp"
        android:textStyle="bold"
        android:layout_below="@id/bookActivity_TV_bookName"

        />
    <TextView
        android:id="@+id/bookActivity_TV_bookDescription"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:text="description book"
        android:layout_below="@id/bookActivity_TV_bookPrice"
        android:layout_marginHorizontal="10dp"
        android:textSize="18sp"
        android:textColor="@color/gray"
        />

    <Button
        android:id="@+id/bookActivity_BTN_AddToCart"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:layout_below="@id/bookActivity_TV_bookDescription"
        android:layout_centerHorizontal="true"
        android:layout_marginTop="10dp"
        android:text="Add To Cart"
        />
</RelativeLayout>